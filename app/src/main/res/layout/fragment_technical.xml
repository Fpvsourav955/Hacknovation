<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/white"
    tools:context=".TechnicalFragment">
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">
    <androidx.cardview.widget.CardView

        android:background="@color/white"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"

        app:cardUseCompatPadding="true"
        app:cardCornerRadius="24dp"
        android:elevation="6dp"
        app:cardElevation="4dp"
   >
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">
            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/souravimgProfile"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:src="@drawable/ic_profile"
                android:scaleType="centerCrop"
                app:civ_border_color="@color/primary"
                app:civ_border_width="1dp"
                android:contentDescription="@string/profile_image" />
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView

                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sourav_kumar_pati"
                    android:fontFamily="@font/poppinsregular"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/black" />

                <TextView

                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_management"
                    android:textAllCaps="true"
                    android:textSize="10sp"
                    android:fontFamily="@font/orbitronregular"
                    android:textColor="@color/persianblue"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp"
                    tools:ignore="SmallSp" />
            </LinearLayout>


            <ImageView
                android:id="@+id/btnCall"
                android:layout_width="36dp"
                android:layout_height="36dp"
                app:tint="@color/primary"
                android:padding="6dp"
                android:src="@drawable/contact"
                android:background="@drawable/icon_bg"
                android:contentDescription="@string/call"/>

            <ImageView
                android:id="@+id/btnMail"

                android:layout_width="36dp"
                app:tint="@color/primary"
                android:layout_height="36dp"
                android:padding="6dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_mail"
                android:background="@drawable/icon_bg"
                android:contentDescription="@string/mail"/>

            <ImageView
                android:id="@+id/btnLinkedin"
                android:layout_width="36dp"
                android:layout_height="36dp"
                app:tint="@color/primary"
                android:padding="8dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/linkedin1"
                android:background="@drawable/icon_bg"
                android:contentDescription="@string/share"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>
    <androidx.cardview.widget.CardView

        android:background="@color/white"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"

        app:cardUseCompatPadding="true"
        app:cardCornerRadius="24dp"
        android:elevation="6dp"
        app:cardElevation="4dp"
        >
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">
            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/subrataimgProfile1"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:src="@drawable/subrata"
                android:scaleType="centerCrop"
                app:civ_border_color="@color/primary"
                app:civ_border_width="1dp"
                android:contentDescription="@string/profile_image" />
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView

                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/subrata_dhibar"
                    android:fontFamily="@font/poppinsregular"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/black" />

                <TextView

                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/web_management"
                    android:textAllCaps="true"
                    android:textSize="10sp"
                    android:fontFamily="@font/orbitronregular"
                    android:textColor="@color/persianblue"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp"
                    tools:ignore="SmallSp" />
            </LinearLayout>


            <ImageView
                android:id="@+id/btnCall1"
                android:layout_width="36dp"
                android:layout_height="36dp"
                app:tint="@color/primary"
                android:padding="6dp"
                android:src="@drawable/contact"
                android:background="@drawable/icon_bg"
                android:contentDescription="@string/call"/>

            <ImageView
                android:id="@+id/btnMail1"
                android:layout_width="36dp"
                app:tint="@color/primary"
                android:layout_height="36dp"
                android:padding="6dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_mail"
                android:background="@drawable/icon_bg"
                android:contentDescription="@string/mail"/>

            <ImageView
                android:id="@+id/btnLinkedin1"
                android:layout_width="36dp"
                android:layout_height="36dp"
                app:tint="@color/primary"
                android:padding="8dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/linkedin1"
                android:background="@drawable/icon_bg"
                android:contentDescription="@string/share"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>
    <androidx.cardview.widget.CardView

        android:background="@color/white"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"

        app:cardUseCompatPadding="true"
        app:cardCornerRadius="24dp"
        android:elevation="6dp"
        app:cardElevation="4dp"
        >
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">
            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/supriyoimgProfile"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:src="@drawable/ic_profile"
                android:scaleType="centerCrop"
                app:civ_border_color="@color/primary"
                app:civ_border_width="1dp"
                android:contentDescription="@string/profile_image" />
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView

                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/supriyo_dawn"
                    android:fontFamily="@font/poppinsregular"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/black" />

                <TextView
                    android:id="@+id/txtRole"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ux_designing"
                    android:textAllCaps="true"
                    android:textSize="10sp"
                    android:fontFamily="@font/orbitronregular"
                    android:textColor="@color/persianblue"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp"
                    tools:ignore="SmallSp" />
            </LinearLayout>


            <ImageView
                android:id="@+id/btnCall2"
                android:layout_width="36dp"
                android:layout_height="36dp"
                app:tint="@color/primary"
                android:padding="6dp"
                android:src="@drawable/contact"
                android:background="@drawable/icon_bg"
                android:contentDescription="@string/call"/>

            <ImageView
                android:id="@+id/btnMail2"
                android:layout_width="36dp"
                app:tint="@color/primary"
                android:layout_height="36dp"
                android:padding="6dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_mail"
                android:background="@drawable/icon_bg"
                android:contentDescription="@string/mail"/>

            <ImageView
                android:id="@+id/btnLinkedin2"
                android:layout_width="36dp"
                android:layout_height="36dp"
                app:tint="@color/primary"
                android:padding="8dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/linkedin1"
                android:background="@drawable/icon_bg"
                android:contentDescription="@string/share"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>

</FrameLayout>